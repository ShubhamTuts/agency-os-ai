<?xml version="1.0"?>
<ruleset name="Agency OS AI - WordPress Plugin Standards">
    <description>Coding standards configuration for Agency OS AI WordPress plugin</description>
    
    <!-- Show sniff codes in output -->
    <arg value="ps"/>
    <arg name="colors"/>
    <arg name="encoding" value="utf-8"/>
    
    <!-- Baseline for ignoring existing issues -->
    <baseline filename="phpcs.baseline.xml"/>
    
    <!-- WordPress Core Rules -->
    <rule ref="WordPress-Core">
        <!-- Exclude strict rules that don't apply to plugin architecture -->
        <exclude name="Generic.Formatting.DisallowMultipleStatements.Found"/>
    </rule>
    
    <!-- WordPress-Extra Rules -->
    <rule ref="WordPress-Extra">
        <exclude name="Generic.Commenting.StubComment.MissingType"/>
    </rule>
    
    <!-- WordPress-Documentation -->
    <rule ref="WordPress-Documentation">
        <exclude name="Generic.Commenting.DocComment.MissingShort"/>
    </rule>
    
    <!-- WordPress -->
    <rule ref="WordPress">
        <!-- Database queries are necessary for plugin models - these are internal tables -->
        <exclude name="WordPress.DB.DirectDatabaseQuery"/>
        <exclude name="WordPress.DB.PreparedSQL"/>
        <exclude name="WordPress.DB.PreparedSQLPlaceholders"/>
        
        <!-- Global prefixes are intentional for plugin namespace -->
        <exclude name="WordPress.NamingConventions.PrefixAllGlobals"/>
        
        <!-- Nonce verification handled at REST API level -->
        <exclude name="WordPress.Security.NonceVerification"/>
        <exclude name="WordPress.Security.ValidatedSanitizedInput"/>
        
        <!-- Variable naming follows project conventions -->
        <exclude name="WordPress.NamingConventions.ValidVariableName"/>
        
        <!-- Hook documentation is optional -->
        <exclude name="Squiz.Commenting.FunctionComment.Missing"/>
        <exclude name="Squiz.Commenting.FunctionComment.ParamCommentVersionNew"/>
    </rule>
    
    <!-- WordPress-VIP-Go - relaxed for plugins -->
    <rule ref="WordPress-VIP-Go">
        <exclude name="VIP.RestrictedFunctions.get_posts_get_posts"/>
        <exclude name="VIP.RestrictedFunctions.wp_remote_get_wp_remote_get"/>
        <exclude name="VIP.RestrictedFunctions.wp_remote_post_wp_remote_post"/>
        <exclude name="VIP.RestrictedFunctions.wp_die"/>
        <exclude name="VIP.Functions.RestrictedFunctions.uploads_uploader"/>
    </rule>
    
    <!-- Generic Rules -->
    <rule ref="Generic">
        <exclude name="Generic.Files.LowerCaseFileName"/>
        <exclude name="Generic.PHP.DisallowShortOpenTag"/>
        <exclude name="Generic.PHP.ForbiddenFunctions"/>
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>
    </rule>
    
    <!-- PSR12 -->
    <rule ref="PSR12">
        <exclude name="PSR12.Properties.ConstantVisibility"/>
    </rule>
    
    <!-- Squiz -->
    <rule ref="Squiz">
        <exclude name="Squiz.ControlStructures.ForEachLoopDeclaration"/>
        <exclude name="Squiz.ControlStructures.ForLoopDeclaration"/>
        <exclude name="Squiz.PHP.Eval"/>
        <exclude name="Squiz.Scope.MemberVarScope"/>
        <exclude name="Squiz.WhiteSpace.ScopeClosingBrace"/>
    </rule>
    
    <!-- PEAR -->
    <rule ref="PEAR">
        <exclude name="PEAR.Functions.FunctionCallSignature"/>
    </rule>
    
    <!-- PHPCompatibility -->
    <rule ref="PHPCompatibility"/>
    
    <!-- Exclude files and directories that don't need checking -->
    <exclude-pattern>build/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>*.min.js</exclude-pattern>
    <exclude-pattern>*.min.css</exclude-pattern>
    <exclude-pattern>docs/*</exclude-pattern>
    
    <!-- Include PHP files -->
    <file>agency-os-ai.php</file>
    <file>uninstall.php</file>
    <dir>includes</dir>
</ruleset>
